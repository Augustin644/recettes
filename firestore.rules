rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /recipes/{recipeId} {
      // Lecture/écriture autorisées uniquement si l'utilisateur est authentifié
      // (même de façon anonyme, ce que l'app fait automatiquement).
      // Ça bloque déjà les robots qui tapent l'API REST sans passer par l'app.
      allow read, write: if request.auth != null;
    }
  }
}
